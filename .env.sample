# .env.sample
# 環境変数のサンプルファイルです。実際に使用する場合は .env を作成し、各値を設定してください。
# フロントエンドのベースURL（例: https://your-app.koyeb.app）
FRONTEND_BASE_URL=https://your-koyeb-app.koyeb.app

# Supabase Postgres 接続(必須)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key


# JWT
JWT_SECRET=please-change
ACCESS_TTL_MIN=120

# Slack（ワークスペース共通のデフォルトWebhook。個別はapp_users.slack_webhookに設定）
SLACK_DEFAULT_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# LINE Messaging API（通知用）
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LONG_LIVED_ACCESS_TOKEN

# LINEログイン（ユーザー認証・連携用）
LINE_LOGIN_CHANNEL_ID=YOUR_LINE_LOGIN_CHANNEL_ID
LINE_LOGIN_CHANNEL_SECRET=YOUR_LINE_LOGIN_CHANNEL_SECRET
LINE_LOGIN_REDIRECT_URI=https://your-koyeb-app.koyeb.app/api/line/callback
OFFICIAL_ACCOUNT_REDIRECT_URI=https://lin.ee/your_official_account_link

# Mailjet（メール送信）
MAILJET_API_KEY=xxxxxxxxxxxxxxxxxxxx
MAILJET_API_SECRET=yyyyyyyyyyyyyyyy

# Wechat Work 小程序（通知用）
AppID=your_appid
AppSecret=your_appsecret
Wechat_CompanyID=your_companyid
