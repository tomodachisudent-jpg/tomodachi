# Development Environment Variables
# DevContainer開発用の環境変数設定

# データベース接続
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/tomodachi_db

# JWT設定
JWT_SECRET=dev-secret-key-change-in-production
ACCESS_TTL_MIN=120

# フロントエンドURL
FRONTEND_BASE_URL=http://localhost:9000

# Supabase (オプション - 本番環境のみ必要)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Slack Webhook (開発中はオプション)
SLACK_DEFAULT_WEBHOOK=

# LINE Messaging API (開発中はオプション)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_REDIRECT_URI=http://localhost:9000/api/line/callback
OFFICIAL_ACCOUNT_REDIRECT_URI=

# Mailjet (開発中はオプション)
MAILJET_API_KEY=
MAILJET_API_SECRET=

# Wechat Work (開発中はオプション)
AppID=
AppSecret=
Wechat_CompanyID=
